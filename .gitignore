# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Production
/build
/dist

# Turbo
.turbo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Environment variables (never commit secrets)
.env
.env.*
!.env.example

# Vercel
.vercel

# Prisma / Database
/prisma/*.db
/prisma/*.db-journal
/db/
*.db
*.db-journal

# Debug & runtime logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
server.log
dev.log
dev.out.log

# OS files
.DS_Store
Thumbs.db

# IDE / editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Certificates
*.pem

# User uploads & generated assets
/upload/
/public/uploads/
/assets/

# Screenshots & local artifacts
screenshot*.png

# Local config & tooling
.neon
.claude
.z-ai-config
local-*
/skills/
prompt

# Mini-services
mini-services/*/node_modules/

# Local test/output directory (not app source tests)
/test
